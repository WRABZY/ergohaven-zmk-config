        mouse_up: mouse_up {
            compatible = "zmk,behavior-mod-morph";
            label = "MOUSE_UP";
            bindings = <&kp UP_ARROW>, <&mmv MOVE_UP>;

            #binding-cells = <0>;
            mods = <(MOD_RCTL)>;
        };

        en_en1h_toru: en_en1h_toru {
            compatible = "zmk,behavior-mod-morph";
            label = "EN_EN1H_TORU";
            bindings = <&to 1>, <&aToLayerRu>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        en1h_en_toru1h: en1h_en_toru1h {
            compatible = "zmk,behavior-mod-morph";
            label = "EN1H_EN_TORU1H";
            bindings = <&to 0>, <&toru1h>;

            #binding-cells = <0>;
